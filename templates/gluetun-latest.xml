<Container version="2">
  <Name>
    Gluetun-Latest
  </Name>
  <Repository>
    qmcgaw/gluetun:latest
  </Repository>
  <Category>
    Network:VPN Network:Privacy Security Tools:Utilities
  </Category>
  <Icon>
    https://raw.githubusercontent.com/qdm12/gluetun/master/doc/logo.svg
  </Icon>
  <Overview>
    <p>
      Gluetun: VPN client in a thin Docker container for multiple VPN providers, written in Go, and using OpenVPN or Wireguard, DNS over TLS, with a few proxy servers built-in.
    </p>
    <p>
      Community Application: The goal of this CA template is to keep all of Gluetun's variables and settings in-sync with the upstream repo / wiki.
    </p>
  </Overview>
  <Project>
    https://github.com/passteque/gluetun
  </Project>
  <Support>
    https://forums.unraid.net/topic/YOUR_SUPPORT_TOPIC
  </Support>
  <TemplateURL>
    https://raw.githubusercontent.com/FiddlyRumpus/unraid-community-apps/refs/heads/main/templates/gluetun.xml
  </TemplateURL>
  
  <Beta>false</Beta>
  <Changes>
    2026-05-15 - Initial relase. Gluetun v3.41.1
  </Changes>
